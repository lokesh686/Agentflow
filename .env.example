# App
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/agentflow_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET_PRIVATE=your-rs256-private-key-here
JWT_SECRET_PUBLIC=your-rs256-public-key-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@agentflowpro.io
SMTP_PASS=your-smtp-password

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Pinecone (Task 11 — vector memory)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_HOST=your-index-host.svc.us-east1-gcp.pinecone.io

# LLM Providers
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Orchestrator (Python service)
ORCHESTRATOR_URL=http://localhost:8001

# Frontend
VITE_API_URL=http://localhost:3000/v1
VITE_WS_URL=http://localhost:3000
